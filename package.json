{
  "name": "hello-dalle-discordbot",
  "version": "1.12.9",
  "description": "Hello Dall-E will produce welcome images for your new users. Now with a wildcard that will 'prompt different' as you specify",
  "main": "bot.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npx tsc",
    "test": "npm run build && jest --config jest.config.ts",
    "test:integration": "RUN_INTEGRATION_TESTS=true npm test -- --testPathPatterns=imageGeneration.integration.test.ts",
    "start": "node dist/bot.js",
    "start:dev": "ts-node src/bot.ts",
    "semantic-release": "semantic-release",
    "prepare": "npx --no-install husky || echo 'husky not available in production'",
    "type-check": "npx tsc --noEmit --skipLibCheck"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "bash -c 'npx tsc --noEmit -p tsconfig.check.json'"
    ]
  },
  "keywords": [],
  "author": "HeavyGee and ChatGPT",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.0",
    "axios": "^1.18.1",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "openai": "^6.48.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jest": "^30.0.0",
    "@types/jimp": "^0.2.28",
    "@types/node": "^25.9.2",
    "axios-mock-adapter": "^2.1.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-mock-axios": "^4.9.0",
    "jest-mock-extended": "^4.0.1",
    "lint-staged": "^17.1.0",
    "semantic-release": "^25.0.8",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
